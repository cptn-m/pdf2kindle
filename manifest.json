{
  "manifest_version": 2,
  "name": "Save Page as PDF to Supabase",
  "version": "1.0",
  "permissions": [
    "activeTab",
    "storage",
    "<all_urls>"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Save PDF to Supabase"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/html2pdf.js/dist/html2pdf.bundle.min.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}